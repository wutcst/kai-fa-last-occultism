  m_text: "\u3010\u535A\u4E3D \u7075\u68A6\u3011\n\u8FD9\u5BB6\u4F19\u662F\u4E2A\u5DEB\u5973\n\u62E5\u6709\u53EF\u4EE5\u98DE\u884C\u7684\u80FD\u529B\n\u6309\u7406\u8BF4\u5979\u5E94\u8BE5\u5728\u5730\u4E0A\u67D0\u4E2A\u5730\u65B9\u5E72\u597D\u5DEB\u5973\u7684\u672C\u5206\uFF08\u9000\u6CBB\u5996\u602A\uFF09\n\n\u4F46\u662F\u4E0D\u77E5\u4E3A\u5565\u8DD1\u5230\u5B87\u5B99\u91CC\u6765\u4E86\n\n\u597D\u50CF\u6709\u4E00\u9996\u6B4C\u5C31\u662F\u5199\u5979\u7684\u3002\u3002\n\u300A\u5B87\u5B99\u5DEB\u5973\u73B0\u8EAB\u300B\uFF1F\n\n\u7ECF\u5178\u7684\u706B\u529B\u914D\u7F6E\u2014\u2014\u4E3A\u65B0\u624B\u51C6\u5907\n\n\u9AD8\u901F\uFF1A
    \u642D\u8F7D\u4E86AI\u7CFB\u7EDF\u7684\u9634\u9633\u7389\n\u4F4E\u901F\uFF1A
    \u9AD8\u901F\u7A7F\u900F\u7684\u5C01\u9B54\u9488\n\n\u7B26\u5361\uFF1A  \u4E39\u9633\xB7\u795E\u9B54\u9053\u6CD5\u7686\u4EBA\u95F4\n\u51B3\u6B7B\uFF1A
    \u5947\u70B9\xB7\u7269\u8D28\u4E9A\u7A7A\u7A74"
